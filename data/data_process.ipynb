import os
from PIL import Image
from tqdm import tqdm
# ===== 配置 =====
input_dir = "./GG_band_raw"
output_dir = "./GG_band_processed"
image_size = 512

os.makedirs(output_dir, exist_ok=True)


def preprocess_image(image_path, save_path):
    try:
        img = Image.open(image_path).convert("RGB")

        # ===== 中心裁剪成正方形 =====
        w, h = img.size
        min_dim = min(w, h)

        left = (w - min_dim) // 2
        top = (h - min_dim) // 2

        img = img.crop((left, top, left + min_dim, top + min_dim))

        # ===== resize =====
        img = img.resize((image_size, image_size), Image.BICUBIC)

        # ===== 保存为高质量 JPG =====
        img.save(save_path, format="JPEG", quality=95, subsampling=0)

    except Exception as e:
        print(f"Error processing {image_path}: {e}")


# ===== 只读取 JPG =====
image_files = [
    f for f in os.listdir(input_dir)
    if f.lower().endswith(".jpg")
]

print(f"Found {len(image_files)} JPG images")

for idx, file in enumerate(tqdm(image_files)):
    input_path = os.path.join(input_dir, file)
    output_path = os.path.join(output_dir, f"{idx:03d}.jpg")

    preprocess_image(input_path, output_path)

print("✅ Done! Processed images saved to:", output_dir)
